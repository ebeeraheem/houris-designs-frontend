# Required. The app fails fast (throws) if this is unset — there is no staging fallback.
# Copy this file to .env.local for local development.
NEXT_PUBLIC_API_BASE_URL=https://api-staging.hourisdesigns.com

# Origin that serves product/swatch/gallery images (Cloudflare R2 / CDN bucket).
# Must be allowlisted in the Content-Security-Policy img-src, or product images
# are blocked by the browser. Set to the environment's image bucket/CDN origin.
NEXT_PUBLIC_IMAGE_BASE_URL=https://pub-71f11e4e8896405ca640ab656f0b6eb0.r2.dev
